# Copy to .env and adjust. Dotenv loads .env automatically for test scripts.

# Running a single test: `node Tests/newMessage.js` — prints wall time via utils/cliTestTiming.js

# --- Suite speed / scope ---
# Skip resetToHome before tests 2+ in runAll (faster; tests must tolerate shared state).
# CONNECT_SKIP_RESET_BETWEEN_TESTS=1

# CreateRoom: smoke = public room only, skip private room block.
# CREATE_ROOM_MODE=smoke

# Markdown examples to run (comma-separated ids). Omit = all examples in markdowns.js.
# MARKDOWN_EXAMPLE_IDS=01_headings,02_emphasis,09_emojis
# Standalone markdown: poll for room name after login (no list scroll in markdowns).
# MARKDOWN_ROOM_WAIT_TIMEOUT_MS=30000
# MARKDOWN_ROOM_WAIT_INTERVAL_MS=600

# Markdown speed: skip per-example screenshots (keeps 01_room_opened); pair with CONNECT_SCREENSHOTS=0 for max savings.
# MARKDOWN_SKIP_EXAMPLE_SCREENSHOTS=1

# Composer waits (defaults in parentheses). Lower = faster, higher flake risk.
# MARKDOWN_COMPOSER_READY_TIMEOUT_MS=10000
# MARKDOWN_COMPOSER_READY_INTERVAL_MS=200
# MARKDOWN_COMPOSER_POST_READY_MS=120
# MARKDOWN_COMPOSER_FALLBACK_PAUSE_MS=500
# Typing pauses now default to 0 (no fixed delay); set only if your device needs extra settle.
# MARKDOWN_TYPE_PLACEHOLDER_PAUSE_MS=0
# MARKDOWN_TYPE_TEXTVIEW_PAUSE_MS=0

# ConversationList: layouts and sorts (comma-separated). Defaults are Classic,Cozy and three sorts.
# CONVERSATION_LAYOUTS=Classic
# CONVERSATION_SORTS=Recent Activity

# Max scroll attempts when finding labels in settings menus (default 10).
# CONVERSATION_SCROLL_MAX=12
# Pause ms between scroll steps in settings (default 260).
# CONVERSATION_SCROLL_PAUSE_MS=260
# Pauses after opening settings / after radio taps (defaults 450 / 350).
# CONVERSATION_MENU_OPEN_PAUSE_MS=450
# CONVERSATION_MENU_ACTION_PAUSE_MS=350

# --- newMessage / PinnedMessageEditFlow list scroll ---
# CONNECT_CONVERSATION_ENTRY_MAX_SCROLLS=24
# CONNECT_CONVERSATION_ENTRY_SCROLL_PAUSE_MS=250

# --- Screenshots ---
# CONNECT_SCREENSHOTS=0
# Or: SKIP_SCREENSHOTS=1

# --- Targets ---
# RECIPIENT=greg.blake
# MARKDOWN_ROOM_NAME=Message Room
# PINNED_EDIT_FLOW_ROOM_NAME=Message Room
