# Copy to .env and adjust. Dotenv loads .env automatically for test scripts.
#
# cp .env.example .env
#
# Required when the login screen appears (localhost server in Login_User.js):
# Connect_username=your@email
# Connect_password=yourpassword

# Running a single test: `node Tests/newMessage.js` — prints wall time via utils/cliTestTiming.js

# --- Suite speed / scope ---
# Skip resetToHome before tests 2+ in runAll (faster; tests must tolerate shared state).
# CONNECT_SKIP_RESET_BETWEEN_TESTS=1

# CreateRoom: smoke = public room only, skip private room block.
# CREATE_ROOM_MODE=smoke

# Markdown examples to run (comma-separated ids). Omit = all examples in markdowns.js.
# MARKDOWN_EXAMPLE_IDS=01_headings,02_emphasis,09_emojis
# Standalone markdown: poll for room name after login (no list scroll in markdowns).
# MARKDOWN_ROOM_WAIT_TIMEOUT_MS=30000
# MARKDOWN_ROOM_WAIT_INTERVAL_MS=600

# Markdown speed: skip per-example screenshots (keeps 01_room_opened); pair with CONNECT_SCREENSHOTS=0 for max savings.
# MARKDOWN_SKIP_EXAMPLE_SCREENSHOTS=1

# Composer waits (defaults in parentheses). Lower = faster, higher flake risk.
# MARKDOWN_COMPOSER_READY_TIMEOUT_MS=10000
# MARKDOWN_COMPOSER_READY_INTERVAL_MS=200
# MARKDOWN_COMPOSER_POST_READY_MS=120
# MARKDOWN_COMPOSER_FALLBACK_PAUSE_MS=500
# Typing pauses now default to 0 (no fixed delay); set only if your device needs extra settle.
# MARKDOWN_TYPE_PLACEHOLDER_PAUSE_MS=0
# MARKDOWN_TYPE_TEXTVIEW_PAUSE_MS=0

# ConversationList: layouts and sorts (comma-separated). Defaults are Classic,Cozy and three sorts.
# CONVERSATION_LAYOUTS=Classic
# CONVERSATION_SORTS=Recent Activity

# Max scroll attempts when finding labels in settings menus (default 10).
# CONVERSATION_SCROLL_MAX=12
# Pause ms between scroll steps in settings (default 260).
# CONVERSATION_SCROLL_PAUSE_MS=260
# Pauses after opening settings / after radio taps (defaults 450 / 350).
# CONVERSATION_MENU_OPEN_PAUSE_MS=450
# CONVERSATION_MENU_ACTION_PAUSE_MS=350

# --- newMessage / PinnedMessageEditFlow list scroll ---
# CONNECT_CONVERSATION_ENTRY_MAX_SCROLLS=24
# CONNECT_CONVERSATION_ENTRY_SCROLL_PAUSE_MS=250

# --- Screenshots ---
# CONNECT_SCREENSHOTS=0
# Or: SKIP_SCREENSHOTS=1

# --- favoriteRoom ---
# Dedicated list row to swipe (default "Favorite Room"). Waits / scrolls list until found.
# FAVORITE_ROOM_NAME=Favorite Room
# FAVORITE_ROOM_WAIT_TIMEOUT_MS=30000
# FAVORITE_ROOM_WAIT_INTERVAL_MS=400
# FAVORITE_ROOM_MAX_SCROLLS=12
# Hold + drag timing for coordinate swipe (default 120ms hold, 200ms move).
# FAVORITE_ROOM_SWIPE_HOLD_MS=120
# FAVORITE_ROOM_SWIPE_MOVE_MS=200
# Optional pauses after login / reset / scroll / swipe (ms; 0 = skip).
# FAVORITE_ROOM_POST_LOGIN_PAUSE_MS=400
# FAVORITE_ROOM_POST_RESET_PAUSE_MS=250
# FAVORITE_ROOM_POST_SCROLL_PAUSE_MS=200
# FAVORITE_ROOM_POST_SWIPE_PAUSE_MS=200

# --- markAsRead (standalone; mark unread / read via swipe right) ---
# MARK_AS_READ_CANDIDATES=Message Room,Markdown room
# MARK_AS_READ_WAIT_TIMEOUT_MS=30000
# MARK_AS_READ_POLL_MS=400

# --- removeRoom (standalone; not in runAll yet) ---
# First visible row whose title contains any of these (comma-separated).
# REMOVE_ROOM_CANDIDATES=A-Public,B-Private
# REMOVE_ROOM_WAIT_TIMEOUT_MS=30000
# REMOVE_ROOM_POLL_MS=400

# --- Targets ---
# RECIPIENT=greg.blake
# MARKDOWN_ROOM_NAME=Message Room
# PINNED_EDIT_FLOW_ROOM_NAME=Message Room

# --- notifications (standalone; simctl push to simulator) ---
# CONNECT_BUNDLE_ID=com.powerhrg.connect.v3.debug
# SIMULATOR_UDID=booted
# NOTIFICATION_PAYLOAD_PATH=Tests/fixtures/connect-notification.apns
# NOTIFICATION_USE_ENV_PAYLOAD=1
# NOTIFICATION_TITLE=Connect
# NOTIFICATION_BODY=New message in Message Room
# NOTIFICATION_ROOM_ID=your-room-id
# NOTIFICATION_EVENT_TYPE=message
# NOTIFICATION_BADGE=1
# NOTIFICATION_SOUND=default
# NOTIFICATION_WAIT_TIMEOUT_MS=15000

# --- membersRoom (standalone; edit modal → Members → Edit flow) ---
# MEMBERS_ROOM_SORT_KEY=M
# MEMBERS_ROOM_TIMEOUT_MS=20000
# MEMBERS_ROOM_INVITEE=greg.blake
# MEMBERS_ROOM_REMOVE_MEMBER=   # optional; omit = first  on edit screen
# MEMBERS_ROOM_SEARCH_PAUSE_MS=800

# --- attachments (standalone; create public AttachmentRoom, in-room setup) ---
# ATTACHMENT_ROOM_SORT_KEY=A
# ATTACHMENT_ROOM_NAME=AttachmentRoom   # optional exact name; omit = A-AttachmentRoom-{rand}
# ATTACHMENT_ROOM_TIMEOUT_MS=20000
# ATTACHMENT_PHOTO_PICKER_TIMEOUT_MS=20000
# ATTACHMENT_PHOTO_MAX_SCROLLS=8
# ATTACHMENT_PHOTO_TAP_PAUSE_MS=200
# ATTACHMENT_PHOTO_MAX_ITEMS=9
# ATTACHMENT_COMPOSER_SETTLE_MS=5000
# ATTACHMENT_PHOTO_GRID_COLS=3
# ATTACHMENT_PHOTO_GRID_ROWS=2
